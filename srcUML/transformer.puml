@startuml

top to bottom direction

scale 0.8
skinparam dpi 200

!theme plain

skinparam defaultTextAlignment center
skinparam ArrowColor #333333
skinparam linetype ortho

skinparam rectangle {
    BorderColor #333333
    RoundCorner 10
}

skinparam node {
    BorderColor #333333
    BackgroundColor White
}

rectangle "Đầu vào: Câu văn tiếng Anh\n(Tối đa 20 từ)" as Input #EAEAEA

rectangle "Token IDs" as Token #EAEAEA

rectangle "Embedding Layer\n(Kích thước: d_model)" as Embedding #DDEBF7

rectangle "Positional Encoding" as PosEncoding #E2EFDA

circle "+" as Add1

package "Transformer Encoder Block\n(Chỉ dùng 1 block)" <<Rectangle>> {

    together {

        rectangle "Self-Attention\n(Scaled Dot-Product)" as SelfAttn #FFF2CC

        rectangle "Layer\nNormalization" as Norm1 #FCE4D6

        rectangle "FeedForward Network\n(Linear → ReLU → Linear)" as FFN #FFF2CC

        rectangle "Layer\nNormalization" as Norm2 #FCE4D6
    }

    circle "+" as Add2
    circle "+" as Add3

    SelfAttn --> Add2
    Add2 --> Norm1

    Norm1 --> FFN

    FFN --> Add3
    Add3 --> Norm2

    Add1 --[bold]> Add2 : Residual
    Norm1 --[bold]> Add3 : Residual
}

rectangle "Mean Pooling" as MeanPool #EAEAEA

rectangle "Classifier Head\n(Mạng tuyến tính)" as Classifier #DDEBF7

rectangle "Đầu ra: 3 Nhãn cảm xúc\n(Positive / Negative / Neutral)" as Output #EAEAEA

Input --> Token
Token --> Embedding

Embedding --> Add1
PosEncoding -right-> Add1 : "Cộng thông tin\nvị trí"

Add1 --> SelfAttn

Norm2 --> MeanPool
MeanPool --> Classifier
Classifier --> Output

@enduml