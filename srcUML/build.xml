<?xml version="1.0" encoding="UTF-8"?>

<project name="PlantUMLExport" default="main">

    <!-- Khai báo task PlantUML -->
    <taskdef name="plantuml"
             classname="net.sourceforge.plantuml.ant.PlantUmlTask">
        <classpath>
            <!-- Đường dẫn tới file plantuml.jar -->
            <pathelement location="plantuml.jar"/>
        </classpath>
    </taskdef>

    <!-- Export toàn bộ file .puml sang SVG -->
    <target name="main">
        <plantuml dir="./src" format="svg" />
    </target>

</project>